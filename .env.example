# Project
COMPOSE_PROJECT_NAME=dnd_saas

# Host loopback ports exposed for Caddy.
DND_FRONTEND_PORT=8090
DND_BACKEND_PORT=8091

# Backend
BACKEND_ENV=production
BACKEND_CORS_ORIGINS=https://dnd.dtmini.com,http://127.0.0.1:8090
BACKEND_SECRET_KEY=change-me-generate-a-long-random-value

# PostgreSQL - DnD only
POSTGRES_DB=dnd_app
POSTGRES_USER=dnd_app
POSTGRES_PASSWORD=change-me-dnd-postgres-password
DATABASE_URL=postgresql://dnd_app:change-me-dnd-postgres-password@dnd-postgres:5432/dnd_app

# Redis - DnD only
REDIS_URL=redis://dnd-redis:6379/0

# MinIO - DnD only
MINIO_ROOT_USER=dnd_minio_admin
MINIO_ROOT_PASSWORD=change-me-dnd-minio-root-password
MINIO_ENDPOINT=http://dnd-minio:9000
MINIO_BUCKET=dnd-assets
MINIO_ACCESS_KEY=dnd_minio_admin
MINIO_SECRET_KEY=change-me-dnd-minio-root-password

